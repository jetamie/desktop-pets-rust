{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "桌面宠物",
  "version": "1.2.1",
  "identifier": "com.desktoppets.app",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "桌面宠物",
        "width": 200,
        "height": 200,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'"],
        "script-src": ["'self'"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "img-src": ["'self'", "asset:", "http://asset.localhost", "https://asset.localhost", "data:", "blob:"]
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["$RESOURCE/assets/pets/**", "$RESOURCE/_up_/assets/pets/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../config", "../assets"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
